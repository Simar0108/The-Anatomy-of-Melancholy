# Data (large files); keep .gitkeep so dirs exist
data/raw/*
!data/raw/.gitkeep
data/processed/*.parquet
data/processed/*.csv
data/features/*
!data/features/.gitkeep
!data/processed/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Models / caches (sentence-transformers, spaCy)
*.bin
*.pt
*.pth
.cache/
